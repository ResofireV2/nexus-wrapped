{
  "manifest_version": 2,
  "name":        "Wrapped",
  "slug":        "wrapped",
  "version":     "1.0.1",
  "module":      "NexusWrapped",
  "description": "A personalised year-in-review for every member of your community.",
  "author":      "billyrayfoss",
  "homepage":    "https://github.com/billyrayfoss/nexus-wrapped",
  "logo_url":    "/ext/wrapped/assets/logo.webp",
  "banner_url":  "/ext/wrapped/assets/banner.webp",
  "js_bundle":   "wrapped.js",

  "notification_types": [
    {
      "key":         "wrapped_ready",
      "label":       "Your Wrapped is ready",
      "description": "Sent when your personal year-in-review has been generated.",
      "icon":        "fa-wand-sparkles",
      "channels":    ["web", "email"],
      "default_preferences": { "web": true, "email": true },
      "payload_schema": {
        "year":     "The year the Wrapped covers",
        "username": "The username the Wrapped was generated for"
      }
    }
  ],

  "routes": [
    { "path": "/",                 "title": "Wrapped" },
    { "path": "/community",        "title": "Community Wrapped" },
    { "path": "/community/:year",  "title": "Community Wrapped" },
    { "path": "/:year/:username",  "title": "Wrapped" }
  ],

  "profile_tabs": [
    {
      "id":         "wrapped",
      "label":      "Wrapped",
      "icon":       "fa-wand-sparkles",
      "visibility": "always",
      "priority":   50
    }
  ],

  "admin_panel": {
    "label": "Wrapped",
    "icon":  "fa-wand-sparkles"
  },

  "explore": {
    "label": "Wrapped",
    "icon":  "fa-wand-sparkles",
    "path":  "/"
  },

  "right_widgets": [
    {
      "id":       "wrapped-community",
      "label":    "Community Wrapped",
      "scope":    "global",
      "priority": 15
    }
  ]
}
